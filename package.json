{
  "name": "runeframe",
  "version": "0.4.5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maivand-rahmani/runeframe.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./experimental": {
      "types": "./dist/experimental/index.d.ts",
      "import": "./dist/experimental/index.js",
      "require": "./dist/experimental/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "REPOSITORY_SETUP.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts src/experimental/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
    "test:integration:smoke": "vitest run --config vitest.integration.config.ts",
    "test:integration:full": "vitest run --config vitest.integration.config.ts --reporter verbose",
    "prepack": "npm run build",
    "pack:check": "npm run build && npm pack --dry-run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "publish:release": "npm publish --access public",
    "publish:beta": "npm publish --tag beta --provenance --access public"
  },
  "dependencies": {
    "ink": "^7.0.2",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "strip-ansi": "^7.2.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
